# =============================================
# Sui Dev Hub - Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# --- Public (exposed to browser) ---

# Google OAuth Client ID for zkLogin
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare Turnstile site key (CAPTCHA)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# Test key (always passes): 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Server-only (never exposed to browser) ---

# Cloudflare Turnstile secret key
# Get from: same Turnstile dashboard as above
TURNSTILE_SECRET_KEY=

# Mysten Enoki API key (for sponsored/gasless transactions)
# Get from: https://enoki.mystenlabs.com/
ENOKI_PRIVATE_KEY=
